# ─── LLM Provider ────────────────────────────────────────────────────────────
# Options: demo | ollama | openai
# demo   → template-based analysis, no LLM needed (default, works in CI)
# ollama → local LLM via Ollama  (https://ollama.com — install first)
# openai → cloud LLM via OpenAI  (requires OPENAI_API_KEY below)
LLM_PROVIDER=demo

# ─── Model selection (optional) ───────────────────────────────────────────────
# Ollama models: llama3.2, llama3.1, mistral, codellama, phi3
# OpenAI models: gpt-3.5-turbo, gpt-4o, gpt-4o-mini
# LLM_MODEL=llama3.2

# ─── OpenAI API Key ───────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=openai
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ─── Vector Store ─────────────────────────────────────────────────────────────
# Directory where ChromaDB persists its data
CHROMA_DB_PATH=./chroma_db
